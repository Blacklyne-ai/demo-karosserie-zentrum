---
import { Phone, Mail, MapPin, Clock, MessageCircle, ArrowUpRight } from "@lucide/astro";
import Icons from "./Icons.astro";
import { site, navServices } from "../data/site";
const year = 2026;
---

<footer class="bg-anthracite-900 text-white">
  <div class="container-prose py-20 lg:py-24">
    <div class="grid gap-12 lg:grid-cols-12">
      <div class="lg:col-span-5 max-w-md">
        <a href="/" class="inline-block">
          <img
            src="/logo.jpg"
            alt="KRZ Karosserie Reparatur Zentrum"
            class="h-14 w-auto bg-white p-2 rounded-lg"
            width="180"
            height="56"
          />
        </a>
        <p class="mt-7 text-[15px] leading-relaxed text-paper-300">
          Karosserie-Fachbetrieb in Hamburg-Stellingen. Karosseriearbeiten, Lackierung,
          Smart-Repair, Oldtimer-Restaurierung und Unfallservice unter einem Dach.
        </p>
        <div class="mt-8 flex items-center gap-3">
          <a
            href={site.social.facebook}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="flex h-11 w-11 items-center justify-center rounded-full border border-white/20 text-white hover:border-krzred hover:bg-krzred transition-all"
          >
            <Icons name="facebook" class="h-4 w-4" />
          </a>
          <a
            href={site.social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="flex h-11 w-11 items-center justify-center rounded-full border border-white/20 text-white hover:border-krzred hover:bg-krzred transition-all"
          >
            <Icons name="instagram" class="h-4 w-4" />
          </a>
          <a
            href={site.whatsapp}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="WhatsApp"
            class="flex h-11 w-11 items-center justify-center rounded-full border border-white/20 text-white hover:border-krzred hover:bg-krzred transition-all"
          >
            <Icons name="whatsapp" class="h-4 w-4" />
          </a>
        </div>
      </div>

      <div class="lg:col-span-3">
        <h4 class="text-[11px] font-semibold uppercase tracking-[0.22em] text-white mb-6">Leistungen</h4>
        <ul class="space-y-3">
          {navServices.slice(0, 6).map((s) => (
            <li>
              <a href={s.href} class="text-sm text-paper-300 hover:text-white transition-colors inline-flex items-center gap-1.5 group">
                {s.label}
                <ArrowUpRight class="h-3 w-3 opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all" />
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="lg:col-span-4">
        <h4 class="text-[11px] font-semibold uppercase tracking-[0.22em] text-white mb-6">Kontakt</h4>
        <ul class="space-y-4 text-sm">
          <li class="flex items-start gap-3">
            <span class="flex h-9 w-9 items-center justify-center rounded-full bg-white/8 shrink-0 mt-0.5">
              <MapPin class="h-4 w-4 text-krzred" />
            </span>
            <div class="text-paper-200 leading-relaxed">
              <span class="text-white font-medium">{site.address.street}</span><br/>
              {site.address.zip} {site.address.city}
            </div>
          </li>
          <li class="flex items-start gap-3">
            <span class="flex h-9 w-9 items-center justify-center rounded-full bg-white/8 shrink-0 mt-0.5">
              <Phone class="h-4 w-4 text-krzred" />
            </span>
            <a href={site.phone.mainTel} class="text-white font-medium hover:text-krzred transition-colors">{site.phone.main}</a>
          </li>
          <li class="flex items-start gap-3">
            <span class="flex h-9 w-9 items-center justify-center rounded-full bg-white/8 shrink-0 mt-0.5">
              <Mail class="h-4 w-4 text-krzred" />
            </span>
            <a href={site.emailHref} class="text-white font-medium hover:text-krzred transition-colors break-all">{site.email}</a>
          </li>
          <li class="flex items-start gap-3">
            <span class="flex h-9 w-9 items-center justify-center rounded-full bg-white/8 shrink-0 mt-0.5">
              <Clock class="h-4 w-4 text-krzred" />
            </span>
            <span class="text-paper-200">{site.hoursShort}</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-16 flex flex-col gap-4 border-t border-white/15 pt-8 lg:flex-row lg:items-center lg:justify-between">
      <p class="text-xs text-paper-300">
        © {year} {site.legal}. Alle Rechte vorbehalten.
      </p>
      <nav class="flex flex-wrap items-center gap-6 text-xs">
        <a href="/kontakt/" class="text-paper-300 hover:text-white transition-colors">Kontakt</a>
        <a href="/impressum/" class="text-paper-300 hover:text-white transition-colors">Impressum</a>
        <a href="/datenschutz/" class="text-paper-300 hover:text-white transition-colors">Datenschutz</a>
      </nav>
    </div>
  </div>
</footer>
