  <!-- ═══════════ STANDORT ═══════════ -->
  <section class="bg-white py-24 lg:py-32 relative overflow-hidden">
    <span aria-hidden="true" class="absolute -top-2 right-4 lg:right-12 display-num pointer-events-none">10</span>
    <div class="container-prose relative">
      <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
        <div class="lg:col-span-5 reveal">
          <span class="eyebrow">Standort</span>
          <h2 class="mt-7 text-3xl sm:text-4xl lg:text-5xl tracking-tight text-balance leading-[1.1]">
            Bornmoor 1.<br/>Hamburg-Stellingen.
          </h2>
          <p class="lead mt-7">
            Auf dem Gelände des Autohofs Stellingen - direkt erreichbar.
          </p>
          <div class="mt-10 space-y-5">
            <div class="flex items-start gap-4"><MapPin class="h-5 w-5 text-krzred shrink-0 mt-0.5" /><div><p class="text-base font-medium text-ink">{site.address.street}</p><p class="text-sm text-ink-500">{site.address.zip} {site.address.city}</p></div></div>
            <div class="flex items-start gap-4"><Phone class="h-5 w-5 text-krzred shrink-0 mt-0.5" /><div><a href={site.phone.mainTel} class="block text-base font-medium text-ink hover:text-krzred transition-colors">{site.phone.main}</a><a href={site.phone.mobileTel} class="block text-sm text-ink-500 hover:text-krzred transition-colors">Mobil: {site.phone.mobile}</a></div></div>
            <div class="flex items-start gap-4"><Mail class="h-5 w-5 text-krzred shrink-0 mt-0.5" /><a href={site.emailHref} class="text-base font-medium text-ink hover:text-krzred transition-colors">{site.email}</a></div>
            <div class="flex items-start gap-4"><Clock class="h-5 w-5 text-krzred shrink-0 mt-0.5" /><ul class="text-sm space-y-1.5">{site.hours.map((h) => (<li class="flex gap-3"><span class="text-ink font-medium w-32">{h.day}</span><span class="text-ink-500">{h.time}</span></li>))}</ul></div>
          </div>
          <div class="mt-10 flex flex-wrap gap-3">
            <a href={site.whatsapp} target="_blank" rel="noopener noreferrer" class="btn-primary"><MessageCircle class="h-4 w-4" />WhatsApp</a>
            <a href={site.mapsLink} target="_blank" rel="noopener noreferrer" class="btn-secondary"><MapPin class="h-4 w-4" />Route planen</a>
          </div>
        </div>
        <div class="lg:col-span-7 reveal-scale">
          <div class="aspect-[5/4] lg:aspect-auto lg:h-full overflow-hidden rounded-3xl bg-paper-200">
            <iframe src={site.mapsEmbed} width="100%" height="100%" style="border:0; min-height: 28rem;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Standort KRZ"></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBand />
