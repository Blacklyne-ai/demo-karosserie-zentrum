---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../data/site";

type Props = {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
};
const {
  title = `${site.name} | Karosserie-Fachbetrieb Hamburg-Stellingen`,
  description = "Karosserieinstandsetzung in Hamburg-Stellingen: Top-Service, Smart-Repair, Richtbankarbeiten, Oldtimer-Restaurierung, Folierung. Termin vereinbaren!",
  ogImage = "/logo.jpg",
  noindex = false,
} = Astro.props as Props;

const localBusiness = {
  "@context": "https://schema.org",
  "@type": "AutoBodyShop",
  name: site.legal,
  image: new URL("/logo.jpg", Astro.site).toString(),
  url: Astro.site?.toString(),
  telephone: site.phone.main,
  email: site.email,
  address: {
    "@type": "PostalAddress",
    streetAddress: site.address.street,
    postalCode: site.address.zip,
    addressLocality: "Hamburg",
    addressRegion: "Stellingen",
    addressCountry: "DE",
  },
  openingHoursSpecification: [
    { "@type": "OpeningHoursSpecification", dayOfWeek: ["Monday","Tuesday","Wednesday","Thursday","Friday"], opens: "09:00", closes: "18:00" },
    { "@type": "OpeningHoursSpecification", dayOfWeek: "Saturday", opens: "09:00", closes: "14:00" },
  ],
  sameAs: [site.social.facebook, site.social.instagram],
};
---

<!doctype html>
<html lang="de-DE">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <meta name="theme-color" content="#0F0F0F" />
    <link rel="icon" type="image/jpeg" href="/logo.jpg" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).toString()} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:locale" content="de_DE" />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" set:html={JSON.stringify(localBusiness)} />
  </head>
  <body>
    <a
      href="#main"
      class="absolute -translate-y-full focus:translate-y-0 focus:top-0 focus:left-0 z-50 bg-krzred text-white px-4 py-2 text-sm"
    >
      Zum Inhalt springen
    </a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
