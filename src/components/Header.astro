---
import { Menu, Phone, ChevronDown } from "@lucide/astro";
import { site, navServices } from "../data/site";
---

<header class="relative border-b border-paper-300 bg-white">
  <div class="container-prose">
    <div class="flex items-center justify-between gap-6 py-5 lg:py-6">
      <a href="/" class="flex items-center gap-3" aria-label="KRZ Startseite">
        <img
          src="/logo.jpg"
          alt="KRZ Karosserie Reparatur Zentrum"
          class="h-11 w-auto"
          width="155"
          height="44"
        />
        <span class="sr-only">{site.name}</span>
      </a>

      <nav class="hidden lg:flex items-center gap-8" aria-label="Hauptnavigation">
        <a href="/" class="text-sm font-medium text-ink hover:text-krzred transition-colors">Willkommen</a>
        <div class="group relative">
          <button class="flex items-center gap-1 text-sm font-medium text-ink hover:text-krzred transition-colors">
            Leistungen
            <ChevronDown class="h-3.5 w-3.5" />
          </button>
          <div class="invisible absolute left-1/2 top-full z-50 mt-3 w-72 -translate-x-1/2 border border-paper-300 bg-white p-3 opacity-0 shadow-xl transition-all group-hover:visible group-hover:opacity-100">
            {navServices.map((s) => (
              <a
                href={s.href}
                class="block px-3 py-2 text-sm text-ink-700 hover:bg-white hover:text-krzred"
              >
                {s.label}
              </a>
            ))}
          </div>
        </div>
        <a
          href={site.partner.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium text-ink hover:text-krzred transition-colors"
        >
          Partner
        </a>
        <a href="/autovermietung/" class="text-sm font-medium text-ink hover:text-krzred transition-colors">Autovermietung</a>
        <a href="/kontakt/" class="text-sm font-medium text-ink hover:text-krzred transition-colors">Kontakt & Anfahrt</a>
      </nav>

      <div class="hidden lg:flex items-center gap-4">
        <a
          href={site.phone.mainTel}
          class="flex items-center gap-2 text-sm font-medium text-ink hover:text-krzred transition-colors"
        >
          <Phone class="h-4 w-4" />
          {site.phone.main}
        </a>
        <a href={site.whatsapp} target="_blank" rel="noopener noreferrer" class="btn-primary text-sm">
          WhatsApp
        </a>
      </div>

      <button
        id="menu-toggle"
        class="lg:hidden flex items-center justify-center h-10 w-10 border border-paper-300 text-ink"
        aria-label="Menü öffnen"
        aria-expanded="false"
      >
        <Menu class="h-5 w-5" />
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="hidden lg:hidden border-t border-paper-300 bg-white"
  >
    <div class="container-prose py-5 space-y-1">
      <a href="/" class="block py-2 text-sm font-medium text-ink">Willkommen</a>
      <details class="group">
        <summary class="flex items-center justify-between py-2 text-sm font-medium text-ink cursor-pointer list-none">
          Leistungen <ChevronDown class="h-3.5 w-3.5 transition group-open:rotate-180" />
        </summary>
        <div class="pl-4 pb-2 space-y-1">
          {navServices.map((s) => (
            <a href={s.href} class="block py-1.5 text-sm text-ink-700">{s.label}</a>
          ))}
        </div>
      </details>
      <a
        href={site.partner.url}
        target="_blank"
        rel="noopener noreferrer"
        class="block py-2 text-sm font-medium text-ink"
      >
        Partner
      </a>
      <a href="/autovermietung/" class="block py-2 text-sm font-medium text-ink">Autovermietung</a>
      <a href="/kontakt/" class="block py-2 text-sm font-medium text-ink">Kontakt & Anfahrt</a>
      <div class="pt-4 flex flex-col gap-3">
        <a href={site.phone.mainTel} class="btn-secondary text-sm">
          <Phone class="h-4 w-4" />
          {site.phone.main}
        </a>
        <a href={site.whatsapp} target="_blank" rel="noopener noreferrer" class="btn-primary text-sm">
          WhatsApp schreiben
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(isOpen));
  });
</script>
