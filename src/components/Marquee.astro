---
const items = [
  "KAROSSERIE",
  "STELLINGEN",
  "LACKIERUNG",
  "SMART-REPAIR",
  "RICHTBANK",
  "OLDTIMER",
  "FOLIERUNG",
  "UNFALLSERVICE",
  "SCHADENMANAGEMENT",
  "ACHSVERMESSUNG",
  "BELEUCHTUNG",
];
const row = items.join("  ◆  ");
---

<section class="section-paper py-10 lg:py-12 overflow-hidden border-y border-paper-300 relative">
  <div class="marquee-row" aria-hidden="true" style="will-change: transform">
    <span>{row}  ◆  </span>
    <span>{row}  ◆  </span>
  </div>
  <p class="sr-only">{items.join(", ")}</p>
</section>
