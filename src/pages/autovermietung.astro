---
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaBand from "../components/CtaBand.astro";
import { site } from "../data/site";
import {
  Car, Key, Calendar, ShieldCheck, Phone, MessageCircle, Check,
  Clock, ArrowRight, ChevronRight, MapPin,
} from "@lucide/astro";

const benefits = [
  { icon: Car, title: "Ersatzwagen während Reparatur", body: "Sie bleiben mobil, während Ihr Auto bei uns in der Werkstatt steht." },
  { icon: Calendar, title: "Kurzfristig verfügbar", body: "Termin am gleichen Tag oder am Folgetag - ohne langen Vorlauf." },
  { icon: ShieldCheck, title: "Versicherung übernimmt", body: "Bei vielen Unfallschäden zahlt die gegnerische Versicherung den Mietwagen." },
  { icon: Key, title: "Übergabe vor Ort", body: "Schlüssel und Papiere direkt bei uns in Bornmoor 1." },
];

const fleet = [
  { class: "Kleinwagen", body: "Sparsam und wendig - ideal für Stadtfahrten in Hamburg." },
  { class: "Kompaktklasse", body: "Mehr Platz und mehr Komfort für die Familie." },
  { class: "Transporter", body: "Falls Sie etwas Größeres transportieren müssen." },
];
---

<BaseLayout
  title="Autovermietung Hamburg-Stellingen | KRZ"
  description="Ersatzwagen-Service während Karosserie-Reparatur in Hamburg-Stellingen. Kurzfristig verfügbar, Versicherungs-Abwicklung inklusive."
>
  <!-- HERO items-center -->
  <section class="bg-cream">
    <div class="container-prose py-16 lg:py-24">
      <nav aria-label="Brotkrumen" class="mb-10 flex items-center gap-1.5 text-xs text-ink-500">
        <a href="/" class="hover:text-krzred">Willkommen</a>
        <ChevronRight class="h-3 w-3" />
        <span class="text-ink">Autovermietung</span>
      </nav>

      <div class="grid gap-10 lg:grid-cols-12 lg:gap-16 items-center">
        <div class="lg:col-span-7">
          <span class="eyebrow">Autovermietung</span>
          <h1 class="mt-7 text-4xl sm:text-5xl lg:text-6xl tracking-tighter text-balance">
            Ersatzwagen, wenn Ihr Auto in der Werkstatt steht.
          </h1>
          <p class="mt-7 text-lg lg:text-xl text-ink-500 max-w-2xl leading-relaxed">
            Sie geben den Schlüssel ab und fahren mit einem unserer Mietwagen weiter. Ohne Drama, ohne Mietwagen-Lotterie, ohne lange Wartezeit.
          </p>
          <div class="mt-10 flex flex-wrap gap-3">
            <a href={site.whatsapp} target="_blank" rel="noopener noreferrer" class="btn-primary">
              <MessageCircle class="h-4 w-4" />
              WhatsApp schreiben
            </a>
            <a href={site.phone.mainTel} class="btn-secondary">
              <Phone class="h-4 w-4" />
              {site.phone.main}
            </a>
          </div>
        </div>
        <div class="lg:col-span-5">
          <div class="aspect-[4/5] overflow-hidden border border-cream-300 bg-cream-200">
            <img
              src="/images/services/autovermietung.jpg"
              alt="KRZ Autovermietung - Ersatzwagen-Service"
              width="800"
              height="1000"
              class="h-full w-full object-cover"
              loading="eager"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BENEFITS GRID -->
  <section class="section-white py-24 lg:py-32 border-y border-cream-300">
    <div class="container-prose">
      <div class="max-w-3xl">
        <span class="eyebrow">Warum bei uns</span>
        <h2 class="mt-6 text-3xl sm:text-4xl lg:text-5xl tracking-tighter text-balance">
          Was unsere Autovermietung anders macht.
        </h2>
        <p class="mt-5 text-lg text-ink-500 leading-relaxed">
          Direkt am Standort, kurzfristig verfügbar, mit Versicherungs-Abwicklung aus einer Hand.
        </p>
      </div>
      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {benefits.map((b) => (
          <div class="card-service">
            <b.icon class="h-7 w-7 text-krzred mb-5" strokeWidth={1.5} />
            <h3 class="text-base font-semibold text-ink mb-2 tracking-tight">{b.title}</h3>
            <p class="text-[13px] text-ink-500 leading-relaxed">{b.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FLOTTE -->
  <section class="section-cream py-24 lg:py-32">
    <div class="container-prose">
      <div class="grid gap-12 lg:grid-cols-12 lg:gap-16 items-start">
        <div class="lg:col-span-5">
          <span class="eyebrow">Fahrzeuge</span>
          <h2 class="mt-6 text-3xl sm:text-4xl lg:text-5xl tracking-tighter text-balance">
            Drei Klassen zur Auswahl.
          </h2>
          <p class="mt-5 text-lg text-ink-500 leading-relaxed">
            Vom Kleinwagen bis zum Transporter - wir haben das passende Fahrzeug für Ihren Bedarf. Sprechen Sie uns an, wir finden was Passendes.
          </p>
        </div>
        <div class="lg:col-span-7 space-y-4">
          {fleet.map((f, i) => (
            <div class="bg-white border border-cream-300 p-6 lg:p-7 flex items-start gap-5">
              <span class="text-2xl font-bold text-krzred tracking-tighter w-8 shrink-0">{String(i + 1).padStart(2, "0")}</span>
              <div>
                <h3 class="text-lg font-semibold text-ink tracking-tight">{f.class}</h3>
                <p class="mt-1.5 text-sm text-ink-500 leading-relaxed">{f.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- INFO STRIP DARK -->
  <section class="section-dark py-20 lg:py-24">
    <div class="container-prose">
      <div class="grid gap-10 md:grid-cols-3 items-end">
        <div>
          <p class="text-5xl lg:text-6xl tracking-tighter font-bold text-cream">1 Tag</p>
          <p class="mt-3 text-sm text-ink-400 max-w-xs leading-relaxed">
            Kurzfristige Verfügbarkeit ohne lange Vorlaufzeit.
          </p>
        </div>
        <div class="md:border-l md:border-ink-400/20 md:pl-10">
          <p class="text-5xl lg:text-6xl tracking-tighter font-bold text-cream">Vor Ort</p>
          <p class="mt-3 text-sm text-ink-400 max-w-xs leading-relaxed">
            Übergabe und Rückgabe direkt in Bornmoor 1.
          </p>
        </div>
        <div class="md:border-l md:border-ink-400/20 md:pl-10">
          <p class="text-5xl lg:text-6xl tracking-tighter font-bold text-cream">Versich.</p>
          <p class="mt-3 text-sm text-ink-400 max-w-xs leading-relaxed">
            Bei Unfallschäden zahlt oft die gegnerische Versicherung.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ABLAUF -->
  <section class="section-light py-24 lg:py-32">
    <div class="container-prose">
      <div class="max-w-3xl">
        <span class="eyebrow">So einfach geht's</span>
        <h2 class="mt-6 text-3xl sm:text-4xl lg:text-5xl tracking-tighter text-balance">
          Drei Schritte. Auto fertig.
        </h2>
      </div>
      <div class="mt-14 grid gap-6 md:grid-cols-3">
        <div class="card-number">
          <span class="number-badge">01</span>
          <Phone class="h-7 w-7 text-krzred mb-5" strokeWidth={1.5} />
          <h3 class="text-xl font-semibold text-ink mb-3 tracking-tight">Anrufen oder WhatsApp</h3>
          <p class="text-sm text-ink-500 leading-relaxed">Sie melden sich kurz. Wir prüfen Verfügbarkeit und Mietdauer und planen direkt einen Termin.</p>
        </div>
        <div class="card-number">
          <span class="number-badge">02</span>
          <Calendar class="h-7 w-7 text-krzred mb-5" strokeWidth={1.5} />
          <h3 class="text-xl font-semibold text-ink mb-3 tracking-tight">Schlüssel-Übergabe</h3>
          <p class="text-sm text-ink-500 leading-relaxed">Sie kommen vorbei - eigenes Auto abstellen, Mietwagen-Schlüssel mitnehmen.</p>
        </div>
        <div class="card-number">
          <span class="number-badge">03</span>
          <Check class="h-7 w-7 text-krzred mb-5" strokeWidth={1.5} />
          <h3 class="text-xl font-semibold text-ink mb-3 tracking-tight">Wechsel zurück</h3>
          <p class="text-sm text-ink-500 leading-relaxed">Wir rufen an, wenn Ihr Wagen fertig ist. Sie geben den Mietwagen zurück und holen Ihr eigenes Auto.</p>
        </div>
      </div>
    </div>
  </section>

  <CtaBand
    eyebrow="Termin sichern"
    title="Brauchen Sie einen Ersatzwagen?"
    body="Schreiben Sie uns kurz auf WhatsApp oder rufen Sie an - wir klären Verfügbarkeit und planen den Termin."
  />
</BaseLayout>
