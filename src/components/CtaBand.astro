---
import { Phone, MessageCircle } from "@lucide/astro";
import { site } from "../data/site";
type Props = {
  title?: string;
  body?: string;
  eyebrow?: string;
};
const {
  eyebrow = "Termin Vereinbaren",
  title = "Karosserie-Schaden? Wir schauen drauf.",
  body = "Schreiben Sie uns per WhatsApp oder rufen Sie kurz an - wir machen Ihnen schnell ein Angebot.",
} = Astro.props as Props;
---

<section class="section-dark relative overflow-hidden">
  <div
    class="absolute inset-0 opacity-[0.08] bg-cover bg-center"
    style="background-image: url('/images/services/oldtimer-restaurierung.jpg');"
  ></div>
  <div class="container-prose relative py-20 lg:py-28">
    <div class="max-w-3xl">
      <span class="eyebrow text-cream-400">
        <span style="background-color:#B91C1C"></span>
        {eyebrow}
      </span>
      <h2 class="mt-6 text-3xl sm:text-4xl lg:text-5xl tracking-tighter text-balance">
        {title}
      </h2>
      <p class="mt-5 text-lg text-ink-400 max-w-2xl leading-relaxed">
        {body}
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-3">
        <a href={site.whatsapp} target="_blank" rel="noopener noreferrer" class="btn-on-dark">
          <MessageCircle class="h-4 w-4" />
          WhatsApp schreiben
        </a>
        <a href={site.phone.mainTel} class="btn-on-dark-ghost">
          <Phone class="h-4 w-4" />
          {site.phone.main}
        </a>
      </div>
    </div>
  </div>
</section>
