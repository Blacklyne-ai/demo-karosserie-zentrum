---
import { MessageCircle, Phone, MapPin, Clock, Star, ArrowRight } from "@lucide/astro";
import { site } from "../data/site";
---

<div class="top-pill relative z-40">
  <div class="container-prose">
    <div class="relative flex items-center justify-between gap-3 text-[12px] py-px">
      <!-- Left side: status + meta -->
      <div class="flex items-center gap-5 min-w-0">
        <span class="flex items-center gap-2 shrink-0">
          <span class="top-pill-dot"></span>
          <span class="font-medium text-white">Geöffnet</span>
          <span class="hidden sm:inline text-steel-500">· {site.hoursShort}</span>
        </span>
        <span class="hidden md:flex items-center gap-1.5 text-steel-500 truncate">
          <MapPin class="h-3 w-3 text-krzred shrink-0" />
          <span class="truncate">Bornmoor 1, Hamburg-Stellingen</span>
        </span>
        <span class="hidden xl:flex items-center gap-1.5 text-steel-500">
          <Star class="h-3 w-3 fill-krzred text-krzred" />
          <span>4.9 / 5 lokal</span>
        </span>
      </div>
      <!-- Right side: contact -->
      <div class="flex items-center gap-4 shrink-0">
        <a
          href={site.phone.mainTel}
          class="hidden sm:flex items-center gap-1.5 text-steel-500 hover:text-white transition-colors"
          aria-label="Anrufen"
        >
          <Phone class="h-3 w-3" />
          <span class="font-medium">{site.phone.main}</span>
        </a>
        <a
          href={site.whatsapp}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-white font-medium hover:text-krzred transition-colors"
          aria-label="WhatsApp schreiben"
        >
          <MessageCircle class="h-3.5 w-3.5" />
          <span>WhatsApp</span>
        </a>
      </div>
    </div>
  </div>
</div>
