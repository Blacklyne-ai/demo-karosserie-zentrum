---
// Brand-Icons (Facebook, Instagram, WhatsApp) als Inline-SVG.
// @lucide/astro hat diese nicht - daher hardcoded paths.
type Props = { name: "facebook" | "instagram" | "whatsapp"; class?: string };
const { name, class: className = "h-5 w-5" } = Astro.props as Props;
