---
import { Menu, Phone, ChevronDown, X, MessageCircle } from "@lucide/astro";
import { site, navServices } from "../data/site";
---

<header class="sticky top-0 z-30 bg-white/85 backdrop-blur-xl border-b border-paper-300/60">
  <div class="container-prose">
    <div class="flex items-center justify-between gap-6 py-3.5 lg:py-4">
      <a href="/" class="flex items-center gap-3 shrink-0" aria-label="KRZ Startseite">
        <img
          src="/logo.jpg"
          alt="KRZ Karosserie Reparatur Zentrum"
          class="h-10 lg:h-11 w-auto"
          width="155"
          height="44"
        />
        <span class="sr-only">{site.name}</span>
      </a>

      <!-- Desktop Nav: Pill Container -->
      <nav class="hidden lg:flex items-center" aria-label="Hauptnavigation">
        <div class="flex items-center gap-1 px-1.5 py-1.5 rounded-full bg-paper-100 border border-paper-300">
          <a href="/" class="px-4 py-2 rounded-full text-[13px] font-medium text-ink hover:bg-white hover:shadow-sm transition-all">Willkommen</a>
          <div class="group relative">
            <button class="flex items-center gap-1 px-4 py-2 rounded-full text-[13px] font-medium text-ink hover:bg-white hover:shadow-sm transition-all">
              Leistungen
              <ChevronDown class="h-3.5 w-3.5" />
            </button>
            <div class="invisible absolute left-1/2 top-full z-50 mt-3 w-72 -translate-x-1/2 rounded-2xl border border-paper-300 bg-white p-3 opacity-0 shadow-2xl transition-all group-hover:visible group-hover:opacity-100">
              {navServices.map((s) => (
                <a
                  href={s.href}
                  class="block px-3 py-2 rounded-lg text-[13px] text-ink-700 hover:bg-paper-100 hover:text-krzred transition-colors"
                >
                  {s.label}
                </a>
              ))}
            </div>
          </div>
          <a
            href={site.partner.url}
            target="_blank"
            rel="noopener noreferrer"
            class="px-4 py-2 rounded-full text-[13px] font-medium text-ink hover:bg-white hover:shadow-sm transition-all"
          >
            Partner
          </a>
          <a href="/autovermietung/" class="px-4 py-2 rounded-full text-[13px] font-medium text-ink hover:bg-white hover:shadow-sm transition-all">Autovermietung</a>
          <a href="/kontakt/" class="px-4 py-2 rounded-full text-[13px] font-medium text-ink hover:bg-white hover:shadow-sm transition-all">Kontakt</a>
        </div>
      </nav>

      <!-- Right side: phone + WhatsApp -->
      <div class="hidden lg:flex items-center gap-3 shrink-0">
        <a
          href={site.phone.mainTel}
          class="flex items-center gap-2 px-3 py-2 rounded-full text-[13px] font-medium text-ink hover:text-krzred transition-colors"
        >
          <Phone class="h-3.5 w-3.5" />
          {site.phone.main}
        </a>
        <a href={site.whatsapp} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 bg-gradient-to-br from-krzred to-krzred-600 text-white px-5 py-2.5 rounded-full text-[13px] font-medium hover:from-krzred-600 hover:to-krzred-700 transition-all shadow-lg shadow-krzred/25">
          <MessageCircle class="h-3.5 w-3.5" />
          WhatsApp
        </a>
      </div>

      <button
        id="menu-toggle"
        class="lg:hidden flex items-center justify-center h-10 w-10 rounded-full border border-paper-300 text-ink hover:border-krzred transition-colors"
        aria-label="Menü öffnen"
        aria-expanded="false"
      >
        <Menu class="h-5 w-5" id="menu-icon-open" />
        <X class="h-5 w-5 hidden" id="menu-icon-close" />
      </button>
    </div>
  </div>

  <!-- Mobile Menu: Compact slide-down -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden border-t border-paper-300 bg-white"
  >
    <div class="container-prose py-4">
      <nav class="space-y-0.5" aria-label="Mobile Navigation">
        <a href="/" class="flex items-center justify-between py-3 text-[15px] font-medium text-ink border-b border-paper-300">
          Willkommen
        </a>
        <details class="group border-b border-paper-300">
          <summary class="flex items-center justify-between py-3 text-[15px] font-medium text-ink cursor-pointer list-none">
            Leistungen
            <ChevronDown class="h-4 w-4 text-krzred transition group-open:rotate-180" />
          </summary>
          <div class="pl-3 pb-3 space-y-1">
            {navServices.map((s) => (
              <a href={s.href} class="block py-1.5 text-[14px] text-ink-700 hover:text-krzred">{s.label}</a>
            ))}
          </div>
        </details>
        <a
          href={site.partner.url}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-between py-3 text-[15px] font-medium text-ink border-b border-paper-300"
        >
          Partner
        </a>
        <a href="/autovermietung/" class="flex items-center justify-between py-3 text-[15px] font-medium text-ink border-b border-paper-300">Autovermietung</a>
        <a href="/kontakt/" class="flex items-center justify-between py-3 text-[15px] font-medium text-ink">Kontakt & Anfahrt</a>
      </nav>
      <div class="pt-4 mt-4 border-t border-paper-300 flex flex-col gap-2">
        <a href={site.whatsapp} target="_blank" rel="noopener noreferrer" class="btn-primary text-sm w-full justify-center">
          <MessageCircle class="h-4 w-4" />
          WhatsApp schreiben
        </a>
        <a href={site.phone.mainTel} class="btn-secondary text-sm w-full justify-center">
          <Phone class="h-4 w-4" />
          {site.phone.main}
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("menu-icon-open");
  const iconClose = document.getElementById("menu-icon-close");
  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(isOpen));
    iconOpen?.classList.toggle("hidden", isOpen);
    iconClose?.classList.toggle("hidden", !isOpen);
  });
</script>
