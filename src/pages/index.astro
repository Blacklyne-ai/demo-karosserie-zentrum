---
import BaseLayout from "../layouts/BaseLayout.astro";
import Marquee from "../components/Marquee.astro";
import CtaBand from "../components/CtaBand.astro";
import { site, services } from "../data/site";
import {
  Hammer, Paintbrush2, Sparkles, Wrench, Award, PaintBucket, Target,
  Lightbulb, AlertTriangle, FileCheck, ArrowRight, Phone, MessageCircle,
  MapPin, Clock, Mail, Star, Check, Eye, Calendar, CheckCircle, Car,
  ShieldCheck, BadgeCheck, Quote, ArrowUpRight,
} from "@lucide/astro";

const iconMap: Record<string, any> = {
  Hammer, Paintbrush2, Sparkles, Wrench, Award, PaintBucket, Target,
  Lightbulb, AlertTriangle, FileCheck,
};

const drei = [
  {
    n: "01",
    title: "Fachbetrieb statt Werkstatt",
    body: "Wir machen Karosserie. Keine Inspektionen, kein TÜV-Service. Fokus auf das, was wir richtig können - vom Smart-Repair bis zur kompletten Karosseriereparatur.",
    icon: Hammer,
    image: "/images/services/karosseriearbeiten.jpg",
  },
  {
    n: "02",
    title: "Versicherung & Unfall aus einer Hand",
    body: "Schadenmanagement, Gutachten, Ersatzwagen, Werkstatt - wir übernehmen die komplette Abwicklung mit Ihrer Versicherung.",
    icon: FileCheck,
    image: "/images/services/schadenmanagement.jpg",
  },
  {
    n: "03",
    title: "Oldtimer-Karosserie mit Geduld",
    body: "Klassiker brauchen Zeit. Wir nehmen sie uns - vom kleinen Rostfleck bis zur kompletten Restaurierung mit Originalsubstanz-Erhalt.",
    icon: Award,
    image: "/images/services/oldtimer-restaurierung.jpg",
  },
];

const process = [
  { n: "01", title: "Schaden ansehen", body: "Kurz vorbeikommen oder Bilder per WhatsApp - wir machen Ihnen ein verbindliches Angebot.", icon: Eye },
  { n: "02", title: "Termin abstimmen", body: "Wir klären Versicherung und Mietwagen, Sie geben den Schlüssel ab.", icon: Calendar },
  { n: "03", title: "Auto abholen", body: "Karosserie wie neu, Lackierung wie vom Werk - Sie holen Ihr Auto fertig ab.", icon: CheckCircle },
];

const showcase = [
  {
    image: "/images/services/karosseriearbeiten.jpg",
    title: "Karosserie-Instandsetzung",
    tag: "Nach Auffahrunfall",
    body: "Komplette Heck-Instandsetzung inkl. Stoßstange, Heckklappe und Lackierung.",
  },
  {
    image: "/images/services/oldtimer-restaurierung.jpg",
    title: "Oldtimer-Restauration",
    tag: "BMW 02 Projekt",
    body: "Bleche neu gefertigt, Rost entfernt, Originalfarbe nach historischer Rezeptur.",
  },
  {
    image: "/images/services/smart-repair.jpg",
    title: "Hagelschaden",
    tag: "Smart-Repair lackschadenfrei",
    body: "Über 40 Dellen entfernt ohne Neulackierung. Same-day-Abwicklung.",
  },
];

const testimonials = [
  {
    quote:
      "Nach einem Auffahrunfall haben die Jungs das komplette Heck instandgesetzt - inklusive Versicherungs-Kommunikation. Der Mietwagen stand am gleichen Tag bereit.",
    context: "Unfallschaden, 2025",
    name: "M. K. aus Stellingen",
  },
  {
    quote:
      "Mein BMW 02 stand seit Jahren in der Garage. Bei KRZ wurde er Blech für Blech instandgesetzt - sauber, ehrlich, mit Originalsubstanz wo möglich.",
    context: "Oldtimer-Restaurierung",
    name: "T. R. aus Hamburg-Nord",
  },
  {
    quote:
      "Hagelschaden auf der Motorhaube - keine Neulackierung nötig. Smart-Repair am gleichen Tag, die Beulen sind weg. Versicherung hat alles übernommen.",
    context: "Smart-Repair Hagel",
    name: "S. W. aus Eimsbüttel",
  },
];
---

<BaseLayout>
  <!-- ═══ HERO ═══ -->
  <section class="relative bg-white mesh-bg overflow-hidden">
    <div class="container-prose relative pt-16 pb-24 lg:pt-24 lg:pb-32">
      <div class="grid gap-12 lg:grid-cols-12 lg:gap-16 items-center">
        <div class="lg:col-span-7">
          <span class="eyebrow">Karosserie-Fachbetrieb seit 2020 - Hamburg-Stellingen</span>
          <h1 class="mt-8 text-4xl sm:text-5xl lg:text-6xl xl:text-7xl tracking-tight text-balance leading-[1.05]">
            Karosserie aus einer Hand,<br/>
            in <span class="brush-underline">Hamburg-Stellingen.</span>
          </h1>
          <p class="lead mt-8">
            KRZ Karosserie Reparatur Zentrum - Karosseriearbeiten, Lackierung, Smart-Repair, Oldtimer-Restaurierung und Unfallservice. Alles unter einem Dach in Bornmoor 1.
          </p>
          <div class="mt-10 flex flex-wrap items-center gap-3">
            <a href={site.whatsapp} target="_blank" rel="noopener noreferrer" class="btn-primary">
              <MessageCircle class="h-4 w-4" />
              WhatsApp schreiben
            </a>
            <a href={site.phone.mainTel} class="btn-secondary">
              <Phone class="h-4 w-4" />
              {site.phone.main}
            </a>
          </div>
          <div class="mt-10 grad-bar w-32"></div>
        </div>

        <div class="lg:col-span-5 relative">
          <div class="aspect-[4/5] w-full overflow-hidden rounded-2xl bg-paper-200 relative img-shine">
            <img
              src="/images/services/header.jpg"
              alt="KRZ Karosserie Reparatur Zentrum Hamburg-Stellingen"
              width="800"
              height="1000"
              class="h-full w-full object-cover transition-transform duration-700 hover:scale-105"
              loading="eager"
              decoding="async"
            />
          </div>

          <!-- Decorative Num-Sticker oben rechts -->
          <div class="num-sticker -top-5 -right-5 hidden md:flex">
            <span class="num-sticker-value">10</span>
            <span class="num-sticker-label">Leistungen</span>
          </div>

          <!-- Floating Standort-Card -->
          <div class="absolute -bottom-6 -left-6 hidden sm:block floating-card-warm max-w-[18rem]">
            <div class="flex items-center gap-2 mb-2">
              <span class="top-pill-dot"></span>
              <p class="text-[11px] uppercase tracking-[0.18em] text-ink-500">Standort</p>
            </div>
            <p class="text-base font-semibold text-ink leading-snug">Bornmoor 1<br/>22525 Hamburg-Stellingen</p>
            <p class="mt-2 text-xs text-ink-500">{site.hoursShort}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ MARQUEE ═══ -->
  <Marquee />

  <!-- ═══ DREI DINGE ═══ -->
  <section class="bg-white py-24 lg:py-32">
    <div class="container-prose">
      <div class="max-w-3xl mb-16 lg:mb-20">
        <span class="eyebrow">Was uns ausmacht</span>
        <h2 class="mt-7 text-3xl sm:text-4xl lg:text-5xl tracking-tight text-balance leading-[1.1]">
          Drei Dinge, die unseren<br/>Betrieb ausmachen.
        </h2>
        <p class="lead mt-7">
          Wir sind kein Werkstatt-Allrounder. Wir sind ein Karosserie-Fachbetrieb - mit klarem Fokus auf das, was wir richtig können.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        {drei.map((d) => (
          <article class="group">
            <div class="relative aspect-[4/3] overflow-hidden rounded-2xl mb-6 img-shine">
              <img
                src={d.image}
                alt={d.title}
                width="600"
                height="450"
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-ink-900/30 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            </div>
            <div class="flex items-center gap-3 mb-3">
              <span class="text-[11px] uppercase tracking-[0.2em] text-krzred">{d.n}</span>
              <div class="h-px flex-1 bg-gradient-to-r from-krzred/40 to-transparent group-hover:from-krzred transition-colors"></div>
            </div>
            <h3 class="text-2xl font-semibold text-ink tracking-tight leading-snug">{d.title}</h3>
            <p class="mt-3 text-[15px] text-ink-500 leading-relaxed">{d.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ 10 LEISTUNGEN GRID ═══ -->
  <section id="leistungen" class="section-paper py-24 lg:py-32">
    <div class="container-prose">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-16 lg:mb-20">
        <div class="max-w-2xl">
          <span class="eyebrow">Leistungen</span>
          <h2 class="mt-7 text-3xl sm:text-4xl lg:text-5xl tracking-tight text-balance leading-[1.1]">
            Zehn Leistungen.<br/>Ein Dach.
          </h2>
          <p class="lead mt-7">
            Vom kleinen Kratzer bis zur kompletten Oldtimer-Restaurierung - alles in der gleichen Werkstatt, ohne Lauferei zwischen drei Betrieben.
          </p>
        </div>
        <a href="/kontakt/" class="hidden lg:inline-flex items-center gap-2 text-sm font-medium text-krzred hover:text-krzred-600 transition-colors group">
          Direkt Kontakt aufnehmen
          <ArrowUpRight class="h-4 w-4 group-hover:-translate-y-0.5 group-hover:translate-x-0.5 transition-transform" />
        </a>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-5">
        {services.map((s) => {
          const Icon = iconMap[s.icon];
          return (
            <a href={`/leistungen/${s.slug}/`} class="card-media group">
              <div class="card-image-wrap">
                <img
                  src={s.image}
                  alt={s.title}
                  loading="lazy"
                  decoding="async"
                  width="640"
                  height="400"
                />
              </div>
              <div class="card-body">
                <Icon class="h-6 w-6 text-krzred mb-4" strokeWidth={1.5} />
                <h3 class="text-base font-semibold text-ink mb-2 tracking-tight">{s.title}</h3>
                <p class="text-[13px] text-ink-500 leading-relaxed mb-4 flex-1">{s.blurb}</p>
                <span class="card-cta">
                  Mehr erfahren
                  <ArrowRight class="h-3.5 w-3.5" />
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ═══ UNFALL & VERSICHERUNG ═══ -->
  <section class="bg-white py-24 lg:py-32">
    <div class="container-prose">
      <div class="grid gap-12 lg:grid-cols-12 lg:gap-20 items-center">
        <div class="lg:col-span-5">
          <span class="eyebrow">Unfall & Versicherung</span>
          <h2 class="mt-7 text-3xl sm:text-4xl lg:text-5xl tracking-tight text-balance leading-[1.1]">
            Unfall?<br/>Wir kümmern uns.
          </h2>
          <p class="lead mt-7">
            Mietwagen, Versicherungs-Kommunikation, Karosserie und Lackierung - alles bei uns, in einem Haus, ohne dass Sie zwischen den Stellen herumtelefonieren müssen.
          </p>
          <div class="mt-9 space-y-4">
            {["Direkter Kontakt zur Versicherung", "Mietwagen-Service vor Ort", "Smart-Repair für Hagelschäden", "Komplett-Abwicklung Anfang bis Ende"].map((t) => (
              <div class="flex items-start gap-3">
                <Check class="h-5 w-5 text-krzred mt-0.5 shrink-0" strokeWidth={2.5} />
                <span class="text-base text-ink">{t}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 flex flex-wrap gap-3">
            <a href="/leistungen/unfallservice/" class="btn-primary">
              Unfall-Service ansehen
              <ArrowRight class="h-4 w-4" />
            </a>
            <a href={site.phone.mobileTel} class="btn-secondary">
              <Phone class="h-4 w-4" />
              Notfall: {site.phone.mobile}
            </a>
          </div>
        </div>

        <div class="lg:col-span-7">
          <div class="aspect-[5/4] overflow-hidden rounded-2xl">
            <img
              src="/images/services/schadenmanagement.jpg"
              alt="Schaden- und Versicherungsmanagement bei KRZ"
              width="900"
              height="720"
              class="h-full w-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ PROCESS ═══ -->
  <section class="section-paper py-24 lg:py-32">
    <div class="container-prose">
      <div class="max-w-3xl mb-16 lg:mb-20">
        <span class="eyebrow">So geht's</span>
        <h2 class="mt-7 text-3xl sm:text-4xl lg:text-5xl tracking-tight text-balance leading-[1.1]">
          Drei Schritte.<br/>Mehr nicht.
        </h2>
        <p class="lead mt-7">
          Wir machen es Ihnen so einfach wie möglich. Sie kommen mit dem Auto, wir machen den Rest - klar, vorhersehbar, ohne Überraschungen.
        </p>
      </div>
      <div class="grid gap-8 md:grid-cols-3">
        {process.map((p) => (
          <div class="bg-white rounded-2xl p-8 lg:p-10 border border-paper-300">
            <div class="flex items-center gap-4 mb-6">
              <span class="text-xs font-medium tracking-[0.2em] text-krzred">{p.n}</span>
              <div class="h-px w-12 bg-krzred/30"></div>
            </div>
            <p.icon class="h-7 w-7 text-krzred mb-5" strokeWidth={1.5} />
            <h3 class="text-xl font-semibold text-ink mb-3 tracking-tight">{p.title}</h3>
            <p class="text-[15px] text-ink-500 leading-relaxed">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ SHOWCASE ═══ -->
  <section class="bg-white py-24 lg:py-32">
    <div class="container-prose">
      <div class="max-w-3xl mb-16 lg:mb-20">
        <span class="eyebrow">Aus der Werkstatt</span>
        <h2 class="mt-7 text-3xl sm:text-4xl lg:text-5xl tracking-tight text-balance leading-[1.1]">
          Echte Projekte.<br/>Echte Kunden.
        </h2>
        <p class="lead mt-7">
          Eine Auswahl aktueller Projekte aus der Werkstatt - vom Unfallschaden bis zum Oldtimer.
        </p>
      </div>
      <div class="grid gap-8 md:grid-cols-3">
        {showcase.map((s, i) => (
          <article class="group">
            <div class="aspect-[4/5] overflow-hidden rounded-2xl mb-6 relative img-shine">
              <img src={s.image} alt={s.title} width="640" height="800" loading="lazy" decoding="async" class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
              <div class="absolute inset-0 bg-gradient-to-t from-ink-900/65 via-ink-900/10 to-transparent"></div>
              <span class="absolute top-4 right-4 num-sticker !static !inline-flex w-12 h-12 bg-white/95">
                <span class="num-sticker-value !text-base">{String(i+1).padStart(2,"0")}</span>
              </span>
              <span class="absolute bottom-4 left-4 chip-light backdrop-blur-md text-white bg-white/15 border-white/20">
                {s.tag}
              </span>
            </div>
            <h3 class="text-xl font-semibold text-ink tracking-tight">{s.title}</h3>
            <p class="mt-2 text-[15px] text-ink-500 leading-relaxed">{s.body}</p>
            <a href={site.whatsapp} target="_blank" rel="noopener noreferrer" class="arrow-link mt-3">
              Detail anfragen
              <ArrowRight class="h-4 w-4" />
            </a>
          </article>
        ))}
      </div>
      <p class="mt-10 text-xs text-ink-500">
        Operator-TODO: echte Vorher/Nachher-Bilder aus dem Betrieb einbinden.
      </p>
    </div>
  </section>

  <!-- ═══ INHABER ═══ -->
  <section class="section-dark py-24 lg:py-32 relative overflow-hidden mesh-bg-dark">
    <div class="container-prose relative">
      <div class="grid gap-12 lg:grid-cols-12 lg:gap-20 items-center">
        <div class="lg:col-span-5">
          <div class="aspect-[4/5] overflow-hidden rounded-2xl bg-anthracite-700">
            <img
              src="/images/services/oldtimer-restaurierung.jpg"
              alt="Werkstatt KRZ Hamburg-Stellingen"
              width="800"
              height="1000"
              class="h-full w-full object-cover opacity-90"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
        <div class="lg:col-span-7">
          <span class="eyebrow text-steel-500">Inhaber</span>
          <h2 class="mt-7 text-3xl sm:text-4xl lg:text-5xl tracking-tight text-balance leading-[1.1] text-white">
            Wir machen Karosserie.<br/>Punkt.
          </h2>
          <p class="lead mt-7 !text-steel-500 !max-w-2xl">
            Madjid Firozi führt KRZ als Karosserie-Fachbetrieb in Hamburg-Stellingen. Kein Allrounder-Versprechen, keine Marketing-Phrasen - sondern klare Spezialisierung auf das, was wir richtig können.
          </p>
          <div class="mt-10 pt-8 border-t border-white/10 grid sm:grid-cols-3 gap-8">
            <div>
              <p class="text-2xl font-semibold text-white tracking-tight">Fokus</p>
              <p class="mt-2 text-sm text-steel-500 leading-relaxed">Nur Karosserie, keine Inspektion.</p>
            </div>
            <div>
              <p class="text-2xl font-semibold text-white tracking-tight">Handwerk</p>
              <p class="mt-2 text-sm text-steel-500 leading-relaxed">Norddeutsch-präzise, ohne Pathos.</p>
            </div>
            <div>
              <p class="text-2xl font-semibold text-white tracking-tight">Klartext</p>
              <p class="mt-2 text-sm text-steel-500 leading-relaxed">Ehrlicher Preis, klare Aussage.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ AUTOVERMIETUNG ═══ -->
  <section class="bg-white py-24 lg:py-32">
    <div class="container-prose">
      <div class="grid gap-12 lg:grid-cols-12 lg:gap-20 items-center">
        <div class="lg:col-span-5 lg:order-2">
          <div class="aspect-[5/4] overflow-hidden rounded-2xl">
            <img
              src="/images/services/autovermietung.jpg"
              alt="Autovermietung als Ersatzwagen-Service"
              width="800"
              height="640"
              class="h-full w-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
        <div class="lg:col-span-7 lg:order-1">
          <span class="eyebrow">Autovermietung</span>
          <h2 class="mt-7 text-3xl sm:text-4xl lg:text-5xl tracking-tight text-balance leading-[1.1]">
            Mietwagen während<br/>der Reparatur?<br/>Direkt vor Ort.
          </h2>
          <p class="lead mt-7">
            Wir vermieten Ersatzwagen selbst - kurzfristig und ohne Mietwagen-Drama. Sie bleiben mobil, während Ihr Auto in unserer Werkstatt steht.
          </p>
          <div class="mt-10 flex flex-wrap gap-3">
            <a href="/autovermietung/" class="btn-primary">
              Zur Autovermietung
              <ArrowRight class="h-4 w-4" />
            </a>
            <a href={site.phone.mainTel} class="btn-secondary">
              <Phone class="h-4 w-4" />
              {site.phone.main}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TESTIMONIALS ═══ -->
  <section class="section-paper py-24 lg:py-32">
    <div class="container-prose">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-16 lg:mb-20">
        <div class="max-w-2xl">
          <span class="eyebrow">Stimmen unserer Kunden</span>
          <h2 class="mt-7 text-3xl sm:text-4xl lg:text-5xl tracking-tight text-balance leading-[1.1]">
            Hamburger Kunden.<br/>Echte Worte.
          </h2>
        </div>
        <div class="flex items-center gap-4">
          <div class="flex flex-col leading-none">
            <span class="text-4xl font-bold text-ink">4.9</span>
            <span class="text-[11px] uppercase tracking-[0.16em] text-ink-500 mt-1">von 5</span>
          </div>
          <div>
            <div class="flex gap-0.5">
              {Array.from({length: 5}).map(() => (<Star class="h-4 w-4 fill-krzred text-krzred" />))}
            </div>
            <p class="text-xs text-ink-500 mt-1">Google + lokal</p>
          </div>
        </div>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        {testimonials.map((t) => (
          <figure class="bg-white rounded-2xl p-8 lg:p-10 border border-paper-300 flex flex-col">
            <Quote class="h-7 w-7 text-krzred mb-5" strokeWidth={1.5} />
            <blockquote class="text-[15px] leading-relaxed text-ink flex-1">
              „{t.quote}"
            </blockquote>
            <figcaption class="mt-7 pt-6 border-t border-paper-300">
              <p class="text-sm font-medium text-ink">{t.name}</p>
              <p class="text-xs text-ink-500 mt-0.5">{t.context}</p>
            </figcaption>
          </figure>
        ))}
      </div>
      <p class="mt-10 text-xs text-ink-500">
        Operator-TODO: Sobald Place-ID vorhanden, durch echte Google-Reviews ersetzen.
      </p>
    </div>
  </section>

  <!-- ═══ STANDORT ═══ -->
  <section class="bg-white py-24 lg:py-32">
    <div class="container-prose">
      <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
        <div class="lg:col-span-5">
          <span class="eyebrow">Standort</span>
          <h2 class="mt-7 text-3xl sm:text-4xl lg:text-5xl tracking-tight text-balance leading-[1.1]">
            Bornmoor 1.<br/>Hamburg-Stellingen.
          </h2>
          <p class="lead mt-7">
            Auf dem Gelände des Autohofs Stellingen - direkt erreichbar mit Auto, S-Bahn S3/S21 und Bus.
          </p>
          <div class="mt-10 space-y-5">
            <div class="flex items-start gap-4">
              <MapPin class="h-5 w-5 text-krzred shrink-0 mt-0.5" />
              <div>
                <p class="text-base font-medium text-ink">{site.address.street}</p>
                <p class="text-sm text-ink-500">{site.address.zip} {site.address.city}</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <Phone class="h-5 w-5 text-krzred shrink-0 mt-0.5" />
              <div>
                <a href={site.phone.mainTel} class="block text-base font-medium text-ink hover:text-krzred transition-colors">
                  {site.phone.main}
                </a>
                <a href={site.phone.mobileTel} class="block text-sm text-ink-500 hover:text-krzred transition-colors">
                  Mobil: {site.phone.mobile}
                </a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <Mail class="h-5 w-5 text-krzred shrink-0 mt-0.5" />
              <a href={site.emailHref} class="text-base font-medium text-ink hover:text-krzred transition-colors">
                {site.email}
              </a>
            </div>
            <div class="flex items-start gap-4">
              <Clock class="h-5 w-5 text-krzred shrink-0 mt-0.5" />
              <ul class="text-sm space-y-1.5">
                {site.hours.map((h) => (
                  <li class="flex gap-3">
                    <span class="text-ink font-medium w-32">{h.day}</span>
                    <span class="text-ink-500">{h.time}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
          <div class="mt-10 flex flex-wrap gap-3">
            <a href={site.whatsapp} target="_blank" rel="noopener noreferrer" class="btn-primary">
              <MessageCircle class="h-4 w-4" />
              WhatsApp
            </a>
            <a href={site.mapsLink} target="_blank" rel="noopener noreferrer" class="btn-secondary">
              <MapPin class="h-4 w-4" />
              Route planen
            </a>
          </div>
        </div>

        <div class="lg:col-span-7">
          <div class="aspect-[5/4] lg:aspect-auto lg:h-full overflow-hidden rounded-2xl bg-paper-200">
            <iframe
              src={site.mapsEmbed}
              width="100%"
              height="100%"
              style="border:0; min-height: 28rem;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Standort KRZ auf Google Maps"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FINAL CTA ═══ -->
  <CtaBand />
</BaseLayout>
