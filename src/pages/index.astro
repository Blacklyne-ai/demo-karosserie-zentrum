          const dates = ["vor 2 Wochen", "vor 1 Monat", "vor 3 Wochen"];
          return (
            <article class="bg-white rounded-2xl p-7 lg:p-8 border border-paper-300 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all flex flex-col reveal" style={`--reveal-delay:${i * 140}ms`}>
