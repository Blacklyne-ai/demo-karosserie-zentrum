---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CtaBand from "../../components/CtaBand.astro";
import { services, site } from "../../data/site";
import {
  Hammer, Paintbrush2, Sparkles, Wrench, Award, PaintBucket,
  Target, Lightbulb, AlertTriangle, FileCheck,
  ArrowRight, Check, MessageCircle, Phone, MapPin, Clock, Mail, ChevronRight,
  BadgeCheck, ShieldCheck, Star, ArrowUpRight, Quote,
} from "@lucide/astro";

export async function getStaticPaths() {
  return services.map((s) => ({ params: { slug: s.slug }, props: { service: s } }));
}

const { service } = Astro.props as { service: typeof services[number] };

const iconMap: Record<string, any> = {
  Hammer, Paintbrush2, Sparkles, Wrench, Award, PaintBucket, Target,
  Lightbulb, AlertTriangle, FileCheck,
};
const Icon = iconMap[service.icon];

const related = services
  .filter((s) => s.slug !== service.slug)
  .sort(() => 0)
  .slice(0, 3);

const title = `${service.title} | KRZ Karosserie-Fachbetrieb Hamburg-Stellingen`;
const description = service.blurb;
---

<BaseLayout title={title} description={description}>
  <!-- HERO items-center -->
  <section class="bg-white relative overflow-hidden mesh-bg">
    <!-- Big watermark service-num right-->
    <div aria-hidden="true" class="absolute top-4 right-[4%] hidden lg:block pointer-events-none select-none">
      <span class="big-num-light">{String(services.findIndex(x => x.slug === service.slug) + 1).padStart(2, "0")}</span>
    </div>
    <div class="absolute inset-0 dot-pattern opacity-40 pointer-events-none"></div>

    <div class="container-prose relative pt-10 pb-20 lg:pt-14 lg:pb-32">
      <nav aria-label="Brotkrumen" class="mb-8 flex items-center gap-1.5 text-xs text-ink-500">
        <a href="/" class="hover:text-krzred">Willkommen</a>
        <ChevronRight class="h-3 w-3" />
        <a href="/#leistungen" class="hover:text-krzred">Leistungen</a>
        <ChevronRight class="h-3 w-3" />
        <span class="text-ink font-medium">{service.title}</span>
      </nav>

      <div class="flex flex-wrap items-center gap-2 mb-8">
        <span class="chip-red">
          <BadgeCheck class="h-3 w-3" />
          Leistung {String(services.findIndex(x => x.slug === service.slug) + 1).padStart(2, "0")} / 10
        </span>
        <span class="chip-light">
          <MapPin class="h-3.5 w-3.5 text-krzred" />
          Hamburg-Stellingen
        </span>
        <span class="hidden sm:inline-flex chip-light">
          <ShieldCheck class="h-3.5 w-3.5 text-krzred" />
          Versicherungs-Partner
        </span>
      </div>

      <div class="grid gap-10 lg:grid-cols-12 lg:gap-16 items-center">
        <div class="lg:col-span-7">
          <h1 class="text-4xl sm:text-5xl lg:text-6xl tracking-tighter text-balance leading-[1.05]">
            {service.hero}
          </h1>
          <p class="lead mt-7">
            {service.intro}
          </p>
          <div class="mt-9 flex flex-wrap gap-3">
            <a href={site.whatsapp} target="_blank" rel="noopener noreferrer" class="btn-primary">
              <MessageCircle class="h-4 w-4" />
              WhatsApp schreiben
            </a>
            <a href={site.phone.mainTel} class="btn-secondary">
              <Phone class="h-4 w-4" />
              {site.phone.main}
            </a>
          </div>

          <!-- Quick benefit-row -->
          <div class="mt-10 pt-8 border-t border-ink-900/8 grid grid-cols-3 gap-3 sm:gap-5">
            <div class="flex items-start gap-2.5">
              <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-krzred/8 shrink-0">
                <Clock class="h-3.5 w-3.5 text-krzred" />
              </span>
              <div>
                <p class="text-[10px] uppercase tracking-[0.16em] text-ink-500">Termin</p>
                <p class="text-xs sm:text-sm font-medium text-ink mt-0.5">kurzfristig</p>
              </div>
            </div>
            <div class="flex items-start gap-2.5">
              <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-krzred/8 shrink-0">
                <ShieldCheck class="h-3.5 w-3.5 text-krzred" />
              </span>
              <div>
                <p class="text-[10px] uppercase tracking-[0.16em] text-ink-500">Versich.</p>
                <p class="text-xs sm:text-sm font-medium text-ink mt-0.5">Direktabwicklung</p>
              </div>
            </div>
            <div class="flex items-start gap-2.5">
              <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-krzred/8 shrink-0">
                <BadgeCheck class="h-3.5 w-3.5 text-krzred" />
              </span>
              <div>
                <p class="text-[10px] uppercase tracking-[0.16em] text-ink-500">Werkstatt</p>
                <p class="text-xs sm:text-sm font-medium text-ink mt-0.5">Stellingen</p>
              </div>
            </div>
          </div>
        </div>

        <div class="lg:col-span-5 relative">
          <!-- Layered Background-Frame -->
          <div aria-hidden="true" class="absolute -top-4 -left-4 right-12 bottom-12 border border-krzred/30 rounded-2xl hidden md:block"></div>
          <div aria-hidden="true" class="absolute top-12 left-12 -right-4 -bottom-4 stripe-banner rounded-2xl hidden md:block"></div>

          <div class="aspect-[4/5] overflow-hidden rounded-2xl bg-paper-200 relative">
            <img
              src={service.image}
              alt={`${service.title} - KRZ Hamburg-Stellingen`}
              width="800"
              height="1000"
              class="h-full w-full object-cover"
              loading="eager"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-ink-900/55 via-transparent to-transparent"></div>
            <!-- Tape sticker -->
            <span class="tape-sticker top-6 -left-3">Original KRZ</span>

            <span class="absolute bottom-4 left-4 chip-dark backdrop-blur-md">
              <Icon class="h-3.5 w-3.5 text-krzred" />
              {service.title}
            </span>
          </div>

          <!-- Floating Stamp -->
          <div class="absolute -top-5 -right-5 hidden md:block stamp-glow z-10">
            <div class="stamp-circle">
              <span class="stamp-circle-num">KRZ</span>
              <span class="stamp-circle-label">Original</span>
            </div>
          </div>

          <!-- Floating Service-Number-Card -->
          <div class="absolute -bottom-6 -left-6 hidden sm:block floating-card-dark max-w-[16rem] z-10">
            <div class="flex items-center gap-2 mb-2">
              <span class="top-pill-dot"></span>
              <p class="text-[10px] uppercase tracking-[0.2em] text-steel-500">Leistung</p>
            </div>
            <p class="text-base font-medium leading-snug">
              {String(services.findIndex(x => x.slug === service.slug) + 1).padStart(2, "0")} / 10 - {service.title}
            </p>
            <div class="mt-3 pt-3 border-t border-white/10 flex items-center gap-2">
              <ArrowRight class="h-3.5 w-3.5 text-krzred" />
              <a href={site.whatsapp} target="_blank" rel="noopener noreferrer" class="text-[11px] text-krzred font-medium">
                Direkt anfragen
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WAS WIR MACHEN (Text + Image Side-by-Side) -->
  <section class="section-white py-24 lg:py-32 border-y border-paper-300 mesh-bg">
    <div class="container-prose">
      <div class="grid gap-12 lg:grid-cols-12 lg:gap-16 items-start">
        <div class="lg:col-span-5">
          <span class="eyebrow-num">
            <span class="eyebrow-num-marker">01</span>
            Was wir machen
          </span>
          <h2 class="mt-6 text-3xl sm:text-4xl lg:text-5xl tracking-tighter text-balance">
            Im Detail.
          </h2>
          <p class="lead mt-6 !text-base lg:!text-lg">
            Diese Punkte sind Teil unserer Arbeit für Sie - sauber dokumentiert, mit Werkstattprotokoll und Garantie auf die ausgeführten Arbeiten.
          </p>
          <div class="mt-10 inline-flex items-center gap-4 p-5 rounded-2xl border border-paper-300 bg-paper-100">
            <span class="flex h-14 w-14 items-center justify-center rounded-xl bg-gradient-to-br from-krzred to-krzred-600 shadow-lg shadow-krzred/20">
              <Icon class="h-7 w-7 text-white" strokeWidth={1.6} />
            </span>
            <div>
              <p class="text-[10px] uppercase tracking-[0.18em] text-ink-500 font-medium">Leistung</p>
              <p class="text-base font-semibold text-ink mt-0.5">{service.title}</p>
            </div>
          </div>
        </div>
        <div class="lg:col-span-7">
          <div class="grid gap-4 sm:grid-cols-2">
            {service.bullets.map((b, i) => (
              <div class="group bg-white border border-paper-300 p-6 rounded-2xl flex items-start gap-4 transition-all duration-300 hover:border-krzred hover:shadow-[0_18px_36px_-12px_rgba(15,15,15,0.10)] hover:-translate-y-1">
                <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-krzred/8 group-hover:bg-krzred transition-colors shrink-0">
                  <Check class="h-4 w-4 text-krzred group-hover:text-white transition-colors" strokeWidth={2.5} />
                </span>
                <div class="flex-1">
                  <span class="text-[10px] font-condensed uppercase tracking-[0.2em] text-krzred">
                    Detail {String(i + 1).padStart(2, "0")}
                  </span>
                  <p class="mt-1 text-[15px] text-ink leading-relaxed">{b}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESS - 3 Schritte -->
  <section class="section-paper py-24 lg:py-32 relative overflow-hidden">
    <div class="container-prose">
      <div class="max-w-3xl mb-14">
        <span class="eyebrow-num">
          <span class="eyebrow-num-marker">02</span>
          Ablauf
        </span>
        <h2 class="mt-6 text-3xl sm:text-4xl lg:text-5xl tracking-tighter text-balance">
          Wie der Prozess läuft.
        </h2>
        <p class="lead mt-6">
          Klar, vorhersehbar, ohne Überraschungen. Drei Schritte vom Erstkontakt bis zur Übergabe.
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-3 relative">
        {service.process.map((p, i) => (
          <div class="group bg-white border border-paper-300 rounded-2xl p-7 lg:p-8 transition-all duration-300 hover:border-krzred hover:shadow-[0_18px_40px_-12px_rgba(15,15,15,0.12)] hover:-translate-y-1">
            <div class="flex items-center justify-between mb-6">
              <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-krzred to-krzred-600 text-white font-condensed text-lg font-bold shadow-lg shadow-krzred/20">
                {String(i + 1).padStart(2, "0")}
              </span>
              <span class="text-[10px] font-condensed uppercase tracking-[0.2em] text-ink-500">
                Step {String(i + 1).padStart(2, "0")}
              </span>
            </div>
            <h3 class="text-xl font-semibold text-ink mb-3 tracking-tight group-hover:text-krzred transition-colors">{p.title}</h3>
            <p class="text-sm text-ink-500 leading-relaxed">{p.body}</p>
            <div class="mt-6 pt-5 border-t border-paper-300 flex items-center justify-between">
              <span class="text-[10px] uppercase tracking-[0.16em] text-ink-500">Phase {String(i + 1).padStart(2, "0")}</span>
              <div class="h-px w-12 bg-gradient-to-r from-krzred to-transparent group-hover:w-20 transition-all duration-500"></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STATS / NUMBERS -->
  {service.stats && (
    <section class="section-dark py-20 lg:py-28 relative overflow-hidden mesh-bg-dark">
      <div class="absolute inset-0 dot-pattern-dark opacity-50 pointer-events-none"></div>
      <div class="container-prose relative">
        <div class="mb-12 max-w-2xl">
          <span class="eyebrow-num">
            <span class="eyebrow-num-marker">03</span>
            In Zahlen
          </span>
          <h2 class="mt-6 text-3xl sm:text-4xl tracking-tighter text-balance text-white">
            Konkret. Verlässlich.
          </h2>
        </div>
        <div class="grid gap-10 md:grid-cols-3">
          {service.stats.map((s, i) => (
            <div class={`group relative ${i > 0 ? "md:border-l md:border-white/10 md:pl-10" : ""}`}>
              <span class="text-[10px] font-condensed uppercase tracking-[0.2em] text-krzred">
                Kennzahl {String(i + 1).padStart(2, "0")}
              </span>
              <p class="stat-display mt-3 whitespace-nowrap">
                {s.value}
              </p>
              <p class="mt-4 text-sm text-steel-500 leading-relaxed max-w-xs">
                {s.label}
              </p>
              <div class="mt-4 h-px bg-gradient-to-r from-krzred to-transparent w-12 group-hover:w-24 transition-all duration-500"></div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- IMAGE-SECTION mit Floating-Card "Häufige Fragen" -->
  <section class="section-light py-24 lg:py-32 relative overflow-hidden">
    <div class="container-prose">
      <div class="grid gap-12 lg:grid-cols-12 lg:gap-16 items-start">
        <div class="lg:col-span-7 relative">
          <div class="aspect-[5/4] overflow-hidden rounded-2xl relative">
            <img
              src={service.image}
              alt={`Werkstattbild ${service.title}`}
              width="900"
              height="720"
              class="h-full w-full object-cover"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-ink-900/40 via-transparent to-transparent"></div>
            <span class="tape-sticker top-6 -left-3">Werkstatt KRZ</span>
          </div>
          <div class="absolute hidden lg:block top-8 right-8 floating-card-warm max-w-[18rem] z-10">
            <div class="flex items-center gap-2 mb-2">
              <MapPin class="h-3.5 w-3.5 text-krzred" />
              <p class="text-[10px] uppercase tracking-[0.18em] text-ink-500">Standort</p>
            </div>
            <p class="text-sm font-medium text-ink leading-snug">Bornmoor 1<br/>Hamburg-Stellingen</p>
            <div class="mt-3 pt-3 border-t border-ink-900/10 flex items-center gap-2">
              <Clock class="h-3.5 w-3.5 text-ink-500" />
              <p class="text-[11px] text-ink-500">{site.hoursShort}</p>
            </div>
          </div>
          <!-- Floating Quote-Card -->
          <div class="absolute hidden lg:flex -bottom-5 -right-5 floating-card-dark max-w-[20rem] z-10 flex-col gap-2">
            <Quote class="h-4 w-4 text-krzred" />
            <p class="text-xs text-white leading-relaxed">
              „Sauber dokumentiert, fair kalkuliert. Bei KRZ weiß ich was auf mich zukommt."
            </p>
            <p class="text-[10px] text-steel-500 mt-1">- Kunde aus Hamburg-Stellingen</p>
          </div>
        </div>
        <div class="lg:col-span-5 lg:pt-6">
          <span class="eyebrow-num">
            <span class="eyebrow-num-marker">04</span>
            Häufige Fragen
          </span>
          <h2 class="mt-6 text-3xl sm:text-4xl tracking-tighter text-balance">
            Sie fragen sich was?
          </h2>
          <p class="lead mt-6 !text-base">
            Kommen Sie vorbei oder schicken Sie uns Bilder per WhatsApp. Wir geben Ihnen eine ehrliche Einschätzung und einen verlässlichen Preis.
          </p>
          <div class="mt-8 space-y-3">
            {[
              { q: "Wie schnell bekomme ich einen Termin?", a: "In der Regel innerhalb weniger Tage. Bei Unfallschäden oft am gleichen Tag - kommen Sie vorbei oder rufen Sie kurz an." },
              { q: "Übernimmt das die Versicherung?", a: "Bei berechtigtem Anspruch ja - wir kümmern uns um die komplette Abwicklung mit der gegnerischen Versicherung." },
              { q: "Bekomme ich einen Ersatzwagen?", a: "Ja - wir vermieten direkt Ersatzwagen oder organisieren Mietfahrzeuge über unseren Partner Autohof Stellingen." },
              { q: "Gibt's Garantie auf die Arbeit?", a: "Auf jede ausgeführte Arbeit. Wir dokumentieren Werkstattprotokoll inklusive verbauter Materialien." },
            ].map((f, i) => (
              <details class="group bg-white border border-paper-300 rounded-2xl overflow-hidden transition-colors hover:border-krzred">
                <summary class="flex items-center justify-between gap-4 cursor-pointer list-none p-5">
                  <div class="flex items-center gap-3 min-w-0">
                    <span class="text-[10px] font-condensed uppercase tracking-[0.2em] text-krzred shrink-0">FAQ {String(i + 1).padStart(2, "0")}</span>
                    <span class="text-sm font-medium text-ink">{f.q}</span>
                  </div>
                  <span class="flex h-7 w-7 items-center justify-center rounded-full bg-krzred/8 group-hover:bg-krzred transition-colors shrink-0">
                    <ChevronRight class="h-3.5 w-3.5 text-krzred group-hover:text-white transition-all group-open:rotate-90" strokeWidth={2.5} />
                  </span>
                </summary>
                <div class="px-5 pb-5 border-t border-paper-300 pt-4">
                  <p class="text-sm text-ink-500 leading-relaxed">{f.a}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="section-paper py-24 lg:py-32 relative overflow-hidden">
    <div class="container-prose">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-14">
        <div>
          <span class="eyebrow-num">
            <span class="eyebrow-num-marker">05</span>
            Weitere Leistungen
          </span>
          <h2 class="mt-6 text-3xl sm:text-4xl tracking-tighter text-balance">
            Was wir sonst noch machen.
          </h2>
        </div>
        <a href="/#leistungen" class="hidden lg:inline-flex items-center gap-2 text-sm font-medium text-krzred hover:text-krzred-600 transition-colors">
          Alle 10 Leistungen ansehen
          <ArrowUpRight class="h-4 w-4" />
        </a>
      </div>
      <div class="grid gap-5 sm:grid-cols-3">
        {related.map((r, i) => {
          const RIcon = iconMap[r.icon];
          return (
            <a href={`/leistungen/${r.slug}/`} class="card-media group relative">
              <div class="card-image-wrap">
                <img src={r.image} alt={r.title} loading="lazy" decoding="async" width="640" height="400" />
                <div class="absolute inset-0 bg-gradient-to-t from-ink-900/60 via-transparent to-ink-900/20 pointer-events-none"></div>
                <span class="badge-num absolute top-3 left-3">{String(i + 1).padStart(2, "0")}</span>
                <span class="badge-icon absolute bottom-3 right-3">
                  <RIcon class="h-5 w-5" strokeWidth={1.6} />
                </span>
                <span class="absolute bottom-3 left-3 chip-dark backdrop-blur-md text-[10px] py-1 px-2">
                  KRZ Original
                </span>
              </div>
              <div class="card-body">
                <h3 class="text-base font-semibold text-ink mb-2 tracking-tight">{r.title}</h3>
                <p class="text-[13px] text-ink-500 leading-relaxed mb-4 flex-1">{r.blurb}</p>
                <div class="flex items-center justify-between pt-3 border-t border-paper-300">
                  <span class="card-cta">
                    Mehr erfahren
                    <ArrowRight class="h-3.5 w-3.5" />
                  </span>
                  <span class="text-[10px] font-condensed uppercase tracking-[0.16em] text-ink-500">Leistung</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <CtaBand
    eyebrow={`${service.title} buchen`}
    title="Brauchen Sie das? Schreiben Sie uns."
    body="Wir machen Ihnen eine ehrliche Einschätzung und einen verlässlichen Preis - per WhatsApp, Telefon oder vor Ort."
  />
</BaseLayout>
