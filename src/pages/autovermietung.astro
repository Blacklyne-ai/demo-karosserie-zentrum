---
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaBand from "../components/CtaBand.astro";
import { site } from "../data/site";
import {
  Car, Key, Calendar, ShieldCheck, Phone, MessageCircle, Check,
  Clock, ArrowRight, ChevronRight, MapPin, ArrowUpRight,
} from "@lucide/astro";

const benefits = [
  { icon: Car, title: "Ersatzwagen während Reparatur", body: "Sie bleiben mobil, während Ihr Auto bei uns in der Werkstatt steht. Direkt am Standort übergeben." },
  { icon: Calendar, title: "Kurzfristig verfügbar", body: "Termin am gleichen Tag oder am Folgetag - ohne langen Vorlauf, ohne Mietwagen-Bürokratie." },
  { icon: ShieldCheck, title: "Versicherung übernimmt", body: "Bei vielen Unfallschäden zahlt die gegnerische Versicherung den Mietwagen vollständig." },
  { icon: Key, title: "Übergabe vor Ort", body: "Schlüssel und Papiere direkt bei uns in Bornmoor 1 - kein zweiter Stopp, keine Lauferei." },
];

const fleet = [
  { class: "Kleinwagen", body: "Sparsam und wendig - ideal für Stadtfahrten in Hamburg." },
  { class: "Kompaktklasse", body: "Mehr Platz und mehr Komfort für die Familie." },
  { class: "Transporter", body: "Falls Sie etwas Größeres transportieren müssen." },
];
---

<BaseLayout
  title="Autovermietung Hamburg-Stellingen | KRZ"
  description="Ersatzwagen-Service während Karosserie-Reparatur in Hamburg-Stellingen. Kurzfristig verfügbar, Versicherungs-Abwicklung inklusive."
>
  <!-- HERO -->
  <section class="bg-white">
    <div class="container-prose pt-12 pb-20 lg:pt-16 lg:pb-28">
      <nav aria-label="Brotkrumen" class="mb-8 flex items-center gap-1.5 text-xs text-ink-500">
        <a href="/" class="hover:text-krzred transition-colors">Willkommen</a>
        <ChevronRight class="h-3 w-3" />
        <span class="text-ink font-medium">Autovermietung</span>
      </nav>

      <div class="grid gap-10 lg:grid-cols-12 lg:gap-16 items-center">
        <div class="lg:col-span-7">
          <span class="eyebrow">Zweites Standbein - Hamburg-Stellingen</span>
          <h1 class="mt-8 text-4xl sm:text-5xl lg:text-6xl tracking-tight text-balance leading-[1.05]">
            Ersatzwagen, wenn Ihr Auto<br/>
            in der <span class="brush-underline">Werkstatt</span> steht.
          </h1>
          <p class="lead mt-8">
            Sie geben den Schlüssel ab und fahren mit einem unserer Mietwagen weiter. Ohne Drama, ohne Mietwagen-Lotterie, ohne lange Wartezeit.
          </p>
          <div class="mt-10 flex flex-wrap gap-3">
            <a href={site.whatsapp} target="_blank" rel="noopener noreferrer" class="btn-primary">
              <MessageCircle class="h-4 w-4" />
              WhatsApp schreiben
            </a>
            <a href={site.phone.mainTel} class="btn-secondary">
              <Phone class="h-4 w-4" />
              {site.phone.main}
            </a>
          </div>
        </div>
        <div class="lg:col-span-5">
          <div class="aspect-[4/5] overflow-hidden rounded-2xl bg-paper-200">
            <img
              src="/images/services/autovermietung.jpg"
              alt="KRZ Autovermietung - Ersatzwagen-Service"
              width="800"
              height="1000"
              class="h-full w-full object-cover"
              loading="eager"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BENEFITS GRID -->
  <section class="section-paper py-24 lg:py-32">
    <div class="container-prose">
      <div class="max-w-3xl mb-16 lg:mb-20">
        <span class="eyebrow">Warum bei uns</span>
        <h2 class="mt-7 text-3xl sm:text-4xl lg:text-5xl tracking-tight text-balance leading-[1.1]">
          Vier Gründe für<br/>unsere Vermietung.
        </h2>
        <p class="lead mt-7">
          Direkt am Standort, kurzfristig verfügbar, mit Versicherungs-Abwicklung aus einer Hand.
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {benefits.map((b) => (
          <div class="bg-white rounded-2xl p-7 border border-paper-300">
            <b.icon class="h-7 w-7 text-krzred mb-5" strokeWidth={1.5} />
            <h3 class="text-base font-semibold text-ink mb-2 tracking-tight">{b.title}</h3>
            <p class="text-[13px] text-ink-500 leading-relaxed">{b.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FLOTTE -->
  <section class="bg-white py-24 lg:py-32">
    <div class="container-prose">
      <div class="grid gap-12 lg:grid-cols-12 lg:gap-16 items-start">
        <div class="lg:col-span-5">
          <span class="eyebrow">Fahrzeuge</span>
          <h2 class="mt-7 text-3xl sm:text-4xl lg:text-5xl tracking-tight text-balance leading-[1.1]">
            Drei Klassen.<br/>Eine Werkstatt.
          </h2>
          <p class="lead mt-7">
            Vom Kleinwagen bis zum Transporter - wir haben das passende Fahrzeug für Ihren Bedarf.
          </p>
          <a href={site.whatsapp} target="_blank" rel="noopener noreferrer" class="btn-primary mt-8">
            <MessageCircle class="h-4 w-4" />
            Verfügbarkeit prüfen
          </a>
        </div>
        <div class="lg:col-span-7 space-y-4">
          {fleet.map((f, i) => (
            <div class="bg-white border border-paper-300 rounded-2xl p-7 flex items-start gap-5">
              <span class="text-xs font-medium tracking-[0.2em] text-krzred pt-1 w-8 shrink-0">{String(i + 1).padStart(2, "0")}</span>
              <div class="flex-1">
                <h3 class="text-xl font-semibold text-ink tracking-tight">{f.class}</h3>
                <p class="mt-1.5 text-[15px] text-ink-500 leading-relaxed">{f.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ABLAUF -->
  <section class="section-paper py-24 lg:py-32">
    <div class="container-prose">
      <div class="max-w-3xl mb-16 lg:mb-20">
        <span class="eyebrow">So einfach</span>
        <h2 class="mt-7 text-3xl sm:text-4xl lg:text-5xl tracking-tight text-balance leading-[1.1]">
          Drei Schritte.<br/>Auto fertig.
        </h2>
      </div>
      <div class="grid gap-8 md:grid-cols-3">
        {[
          { n: "01", t: "Anrufen oder WhatsApp", b: "Sie melden sich kurz. Wir prüfen Verfügbarkeit und Mietdauer und planen direkt einen Termin." },
          { n: "02", t: "Schlüssel-Übergabe", b: "Sie kommen vorbei - eigenes Auto abstellen, Mietwagen-Schlüssel mitnehmen." },
          { n: "03", t: "Wechsel zurück", b: "Wir rufen an, wenn Ihr Wagen fertig ist. Sie geben den Mietwagen zurück und holen Ihr Auto." },
        ].map((p) => (
          <div class="bg-white rounded-2xl p-8 lg:p-10 border border-paper-300">
            <div class="flex items-center gap-4 mb-6">
              <span class="text-xs font-medium tracking-[0.2em] text-krzred">{p.n}</span>
              <div class="h-px w-12 bg-krzred/30"></div>
            </div>
            <h3 class="text-xl font-semibold text-ink mb-3 tracking-tight">{p.t}</h3>
            <p class="text-[15px] text-ink-500 leading-relaxed">{p.b}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBand
    eyebrow="Termin sichern"
    title="Brauchen Sie einen Ersatzwagen?"
    body="Schreiben Sie uns kurz auf WhatsApp oder rufen Sie an - wir klären Verfügbarkeit und planen den Termin."
  />
</BaseLayout>
