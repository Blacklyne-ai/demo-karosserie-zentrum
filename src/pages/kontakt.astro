---
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaBand from "../components/CtaBand.astro";
import { site } from "../data/site";
import {
  MapPin, Phone, Mail, Clock, MessageCircle, Car, Bus, ArrowRight, ChevronRight,
} from "@lucide/astro";

const contact = [
  { icon: MessageCircle, title: "WhatsApp schreiben", value: site.phone.mobile, href: site.whatsapp, hint: "Schnellste Antwort - Bilder direkt schicken" },
  { icon: Phone, title: "Festnetz anrufen", value: site.phone.main, href: site.phone.mainTel, hint: "Mo - Fr 9 - 18 · Sa 9 - 14" },
  { icon: Phone, title: "Mobil erreichen", value: site.phone.mobile, href: site.phone.mobileTel, hint: "Auch außerhalb der Öffnungszeiten" },
  { icon: Mail, title: "E-Mail senden", value: site.email, href: site.emailHref, hint: "Antwort innerhalb 1 Werktag" },
];
---

<BaseLayout
  title="Kontakt & Anfahrt | KRZ Karosserie-Fachbetrieb Hamburg-Stellingen"
  description="Bornmoor 1, 22525 Hamburg-Stellingen. Telefon, WhatsApp, E-Mail. Mo - Fr 9 - 18, Sa 9 - 14. Direkt zu uns - wir helfen schnell weiter."
>
  <!-- HERO items-center -->
  <section class="bg-cream">
    <div class="container-prose py-16 lg:py-24">
      <nav aria-label="Brotkrumen" class="mb-10 flex items-center gap-1.5 text-xs text-ink-500">
        <a href="/" class="hover:text-krzred">Willkommen</a>
        <ChevronRight class="h-3 w-3" />
        <span class="text-ink">Kontakt & Anfahrt</span>
      </nav>

      <div class="grid gap-10 lg:grid-cols-12 lg:gap-16 items-center">
        <div class="lg:col-span-7">
          <span class="eyebrow">Kontakt & Anfahrt</span>
          <h1 class="mt-7 text-4xl sm:text-5xl lg:text-6xl tracking-tighter text-balance">
            Schreiben Sie uns - wir schauen drauf.
          </h1>
          <p class="mt-7 text-lg lg:text-xl text-ink-500 max-w-2xl leading-relaxed">
            Per WhatsApp, Telefon oder E-Mail. Wir antworten schnell und machen Ihnen ein ehrliches Angebot. Bilder vom Schaden helfen uns, schneller einzuschätzen.
          </p>
          <div class="mt-10 flex flex-wrap gap-3">
            <a href={site.whatsapp} target="_blank" rel="noopener noreferrer" class="btn-primary">
              <MessageCircle class="h-4 w-4" />
              WhatsApp schreiben
            </a>
            <a href={site.phone.mainTel} class="btn-secondary">
              <Phone class="h-4 w-4" />
              {site.phone.main}
            </a>
          </div>
        </div>
        <div class="lg:col-span-5">
          <div class="bg-anthracite-800 text-cream p-7 lg:p-8">
            <p class="text-xs uppercase tracking-[0.2em] text-cream-400">Adresse</p>
            <p class="mt-3 text-2xl font-semibold tracking-tight leading-tight">Bornmoor 1<br/>22525 Hamburg-Stellingen</p>
            <div class="mt-7 pt-6 border-t border-cream-400/15">
              <p class="text-xs uppercase tracking-[0.2em] text-cream-400">Öffnungszeiten</p>
              <ul class="mt-3 space-y-1.5 text-sm">
                {site.hours.map((h) => (
                  <li class="flex gap-3">
                    <span class="w-36 text-cream">{h.day}</span>
                    <span class="text-cream-400">{h.time}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- KONTAKT-KANÄLE -->
  <section class="section-white py-24 lg:py-32 border-y border-cream-300">
    <div class="container-prose">
      <div class="max-w-3xl">
        <span class="eyebrow">Direkt erreichbar</span>
        <h2 class="mt-6 text-3xl sm:text-4xl lg:text-5xl tracking-tighter text-balance">
          Vier Wege zu uns.
        </h2>
        <p class="mt-5 text-lg text-ink-500 leading-relaxed">
          Wählen Sie den Kanal, der für Sie am schnellsten passt - wir antworten auf allen.
        </p>
      </div>
      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {contact.map((c) => (
          <a href={c.href} target={c.href.startsWith("http") ? "_blank" : "_self"} rel="noopener noreferrer" class="card-service">
            <c.icon class="h-7 w-7 text-krzred mb-5" strokeWidth={1.5} />
            <p class="text-xs uppercase tracking-[0.16em] text-ink-500 font-medium mb-2">{c.title}</p>
            <p class="text-base font-semibold text-ink mb-2 tracking-tight break-all">{c.value}</p>
            <p class="text-[13px] text-ink-500 leading-relaxed">{c.hint}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- MAPS + ANFAHRT -->
  <section class="section-cream py-24 lg:py-32">
    <div class="container-prose">
      <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
        <div class="lg:col-span-5">
          <span class="eyebrow">Anfahrt</span>
          <h2 class="mt-6 text-3xl sm:text-4xl tracking-tighter text-balance">
            So finden Sie zu uns.
          </h2>
          <p class="mt-5 text-base text-ink-500 leading-relaxed">
            Bornmoor 1 liegt im Autohof Stellingen - auf einem der größten Autogewerbehöfe in Hamburg. Direkt erreichbar mit dem Auto und gut angebunden mit dem ÖPNV.
          </p>
          <div class="mt-9 space-y-5">
            <div class="flex items-start gap-3.5">
              <Car class="h-5 w-5 text-krzred shrink-0 mt-0.5" />
              <div>
                <p class="text-sm font-medium text-ink">Mit dem Auto</p>
                <p class="text-sm text-ink-500 leading-relaxed">Über die A7 (Abfahrt Stellingen) oder die B4. Parkplätze auf dem Gelände.</p>
              </div>
            </div>
            <div class="flex items-start gap-3.5">
              <Bus class="h-5 w-5 text-krzred shrink-0 mt-0.5" />
              <div>
                <p class="text-sm font-medium text-ink">Mit dem ÖPNV</p>
                <p class="text-sm text-ink-500 leading-relaxed">S-Bahn S3/S21 Station Stellingen, von dort wenige Minuten zu Fuß oder Bus.</p>
              </div>
            </div>
            <div class="flex items-start gap-3.5">
              <MapPin class="h-5 w-5 text-krzred shrink-0 mt-0.5" />
              <div>
                <p class="text-sm font-medium text-ink">Auf dem Gelände</p>
                <p class="text-sm text-ink-500 leading-relaxed">Im Autohof Stellingen - größter Autogewerbehof der Region, viele Werkstätten unter einem Dach.</p>
              </div>
            </div>
          </div>
          <a href={site.mapsLink} target="_blank" rel="noopener noreferrer" class="mt-9 inline-flex btn-secondary text-sm">
            <MapPin class="h-4 w-4" />
            Route in Google Maps öffnen
          </a>
        </div>

        <div class="lg:col-span-7">
          <div class="aspect-[5/4] lg:aspect-auto lg:h-full overflow-hidden border border-cream-300 bg-cream-200">
            <iframe
              src={site.mapsEmbed}
              width="100%"
              height="100%"
              style="border:0; min-height: 32rem;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="KRZ Standort auf Google Maps"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>
